                                        <h3 class="text-sm font-bold text-white border-b border-white/5 pb-2">рҹ’¬ зҡҮе®¶дҝұд№җйғЁе…Ёе‘ҳзғӯи®®еўҷ</h3>
                                        <div id="post-wall" class="space-y-3">
                                            <div class="glass-card p-4 rounded-xl space-y-2">
                                                <div class="flex justify-between items-center text-xs"><span class="text-gold font-bold">еӨ§й©¬зҹӯеү§дёҖе“Ҙ рҹ‘‘</span><span class="text-slate-500 text-[10px]">3еҲҶй’ҹеүҚ</span></div>
                                                <p class="text-white text-xs leading-relaxed">еҲҡеҲҡеңЁ Royal Blue зңӢе®ҢгҖҠең°еәңе®ўжңҚдёӯеҝғгҖӢеүҚ5йӣҶпјҢз¬‘ж–ҷеӨӘи¶ідәҶпјҒз¬¬6йӣҶеұ…з„¶жҳҜдёӘи¶…зә§еӨ§еҸҚиҪ¬еҚЎзӮ№пјҢзҲұдәҶзҲұдәҶпјҒ</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        
                            <div id="user-page" class="page-content max-w-[1400px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col items-center justify-center hidden">
                                <div class="max-w-md w-full glass-card rounded-2xl p-6 text-center space-y-6">
                                    <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-gold to-yellow-600 mx-auto flex items-center justify-center border-4 border-[#071A3D] shadow-xl"><span class="text-3xl">рҹӨө</span></div>
                                    <div>
                                        <h3 class="text-lg font-black text-white tracking-wide">е°ҠиҙөзҡҮе®¶дјҡе‘ҳ_0894</h3>
                                        <p class="text-[10px] text-gold uppercase tracking-widest font-bold mt-1">рҹ’Һ VIP дјҡе‘ҳзӯүзә§: V2 й’»зҹізә§дҝұд№җйғЁ</p>
                                    </div>
                                    <div class="grid grid-cols-2 gap-2 border-t border-b border-white/5 py-4 text-left text-xs">
                                        <div>иҙҰжҲ·зҠ¶жҖҒ: <span class="text-green-400 font-bold">жӯЈеёё</span></div>
                                        <div>з§ҜеҲҶдҪҷйўқ: <span class="text-gold font-bold id-point-placeholder">45</span> Pt</div>
                                    </div>
                                    <div class="space-y-2">
                                        <p class="text-[11px] text-slate-400">жӣҙжөҒз•…зҡ„йҳІж–ӯжөҒзәҜеҮҖиҝҪеү§дҪ“йӘҢпјҢе»әи®®з«ӢеҲ»е®үиЈ…зӢ¬з«Ӣе®ўжҲ·з«Ҝпјҡ</p>
                                        <button onclick="alert('зӢ¬з«Ӣй«ҳйҳІ Android APK жӯЈеңЁеҗҜеҠЁеҠ еҜҶйҖҡйҒ“дёӢиҪҪ...')" class="w-full bg-gradient-to-r from-[#b8922f] to-[#D4AF37] text-[#071A3D] font-black py-3 rounded-xl text-xs uppercase tracking-widest shadow-md">рҹ“І Android APK е®ҳж–№е®үе…ЁдёӢиҪҪ</button>
                                    </div>
                                </div>
                            </div>
                        
                            <footer class="bg-[#041129] border-t border-white/5 mt-12 py-6 text-center text-xs text-slate-500"><p>Copyright В© 2026 Royal Blue Club. All Rights Reserved.</p></footer>
                        
                            <script>
                                let currentPoints = 45;
                        
                                // 1. ж ёеҝғеҜјиҲӘеӨҡйЎөжҺ§еҲ¶
                                function switchPage(pageId) {
                                    document.querySelectorAll('.page-content').forEach(p => p.classList.add('hidden'));
                                    document.getElementById(pageId).classList.remove('hidden');
                        
                                    // еҜјиҲӘй«ҳдә®жё…з©ә
                                    const navs = ['nav-home', 'nav-vip', 'nav-tasks', 'nav-com'];
                                    navs.forEach(n => { if(document.getElementById(n)) document.getElementById(n).className = "hover:text-gold transition"; });
                        
                                    if(pageId === 'home-page' && document.getElementById('nav-home')) document.getElementById('nav-home').className = "text-gold border-b-2 border-gold-bright pb-1";
                                    if(pageId === 'vip-page' && document.getElementById('nav-vip')) document.getElementById('nav-vip').className = "text-gold border-b-2 border-gold-bright pb-1";
                                    if(pageId === 'tasks-page' && document.getElementById('nav-tasks')) document.getElementById('nav-tasks').className = "text-gold border-b-2 border-gold-bright pb-1";
                                    if(pageId === 'com-page' && document.getElementById('nav-com')) document.getElementById('nav-com').className = "text-gold border-b-2 border-gold-bright pb-1";
                        
                                    window.scrollTo({ top: 0, behavior: 'smooth' });
                                }
                        
                                // 2. жЁЎжӢҹиҝӣе…Ҙзҹӯеү§иҜҰжғ…йЎөе№¶еҠЁжҖҒй“әжҺ’ 20 йӣҶ
                                function goToPlay(movieTitle, targetEpisode) {
                                    switchPage('play-page');
                                    document.getElementById('detail-movie-title').innerText = movieTitle;
                                    
                                    const grid = document.getElementById('episode-grid');
                                    grid.innerHTML = ''; // жё…з©ә
                        
                                    for (let i = 1; i <= 20; i++) {
                                        const btn = document.createElement('button');
                                        btn.className = "ep-btn py-3 rounded-xl text-xs font-bold relative flex items-center justify-center";
                                        
                                        if (i <= 5) {
                                            btn.innerHTML = `${i} <span class="absolute top-0 right-0 text-[8px] bg-green-600 text-white px-1 rounded-bl-md rounded-tr-xl">е…Қиҙ№</span>`;
                                            btn.onclick = () => loadVideoState(movieTitle, i, true);
                                        } else {
                                            btn.innerHTML = `${i} <span class="absolute top-0 right-0 text-[8px] bg-amber-600 text-white px-1 rounded-bl-md rounded-tr-xl">рҹ”’</span>`;
                                            btn.onclick = () => loadVideoState(movieTitle, i, false);
                                        }
                                        grid.appendChild(btn);
                                    }
                                    // й»ҳи®ӨеҠ иҪҪз¬¬дёҖйӣҶ
                                    loadVideoState(movieTitle, targetEpisode, targetEpisode <= 5);
                                }
                        
                                // 3. еү§йӣҶйүҙжқғжӢҰжҲӘзҪ‘е…ізҠ¶жҖҒеҲҮжҚў
                                function loadVideoState(title, num, isFree) {
                                    document.getElementById('current-playing-title').innerText = `${title} - з¬¬ ${num} йӣҶ`;
                                    if (isFree) {
                                        document.getElementById('player-state-free').classList.remove('hidden');
                                        document.getElementById('player-state-locked').classList.add('hidden');
                                    } else {
                                        document.getElementById('player-state-free').classList.add('hidden');
                                        document.getElementById('player-state-locked').classList.remove('hidden');
                                        openModal(); // иҮӘеҠЁжӢүиө·еҸҢйҮҚеҸҳзҺ°жӢҰжҲӘеј№зӘ—
                                    }
                                }
                        
                                // 4. зӨҫеҢәеҠЁжҖҒеҸ‘её–еҠҹиғҪ
                                function submitPost() {
                                    const input = document.getElementById('post-input');
                                    if(!input.value.trim()) return alert('иҜ·иҫ“е…ҘдёҖдәӣжғіжі•еҶҚеҸ‘еёғе“ҰпјҒ');
                                    
                                    const wall = document.getElementById('post-wall');
                                    const newPost = document.createElement('div');
                                    newPost.className = "glass-card p-4 rounded-xl space-y-2 animate-fadeIn";
                                    newPost.innerHTML = `
                                        <div class="flex justify-between items-center text-xs"><span class="text-gold font-bold">е°ҠиҙөзҡҮе®¶дјҡе‘ҳ_0894 рҹ’Һ</span><span class="text-slate-500 text-[10px]">еҲҡеҲҡ</span></div>
                                        <p class="text-white text-xs leading-relaxed">${input.value}</p>
                                    `;
                                    wall.insertBefore(newPost, wall.firstChild);
                                    input.value = '';
                                }
                        
                                // 5. иҫ…еҠ©еўһеҲҶеҷЁпјҲжј”зӨәз”Ёпјү
                                function addPoints(amt, msg) {
                                    currentPoints += amt;
                                    document.getElementById('user-points').innerText = currentPoints;
                                    document.querySelectorAll('.id-point-placeholder').forEach(el => el.innerText = currentPoints);
                                    alert(msg);
                                }
                        
                                function openModal() { document.getElementById('conversion-modal').classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
                                function closeModal() { document.getElementById('conversion-modal').classList.add('hidden'); document.body.style.overflow = ''; }
                            </script>
                        </body>
                        </html>
                        