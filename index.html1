<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Royal Blue Club - 顶级皇家短剧娱乐社区</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background: radial-gradient(circle at top, #0c2554 0%, #071A3D 100%); color: #e2e8f0; font-family: system-ui, -apple-system, sans-serif; }
        .text-gold { color: #D4AF37; }
        .bg-gold { background-color: #D4AF37; }
        .border-gold { border-color: rgba(212, 175, 55, 0.15); }
        .border-gold-bright { border-color: #D4AF37; }
        .glass-card { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(212, 175, 55, 0.15); }
        .glass-card:hover { border: 1px solid rgba(212, 175, 55, 0.4); box-shadow: 0 0 20px rgba(212, 175, 55, 0.1); }
        .ep-btn { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); transition: all 0.2s; }
        .ep-btn:hover { border-color: #D4AF37; color: #D4AF37; }
    </style>
</head>
<body class="min-h-screen flex flex-col relative">

    <div id="conversion-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm hidden">
        <div class="relative w-full max-w-md bg-gradient-to-b from-[#0c2554] to-[#071A3D] rounded-2xl border-2 border-[#D4AF37] p-6 text-center shadow-2xl">
            <button onclick="closeModal()" class="absolute top-4 right-4 text-slate-400 hover:text-[#D4AF37]">✕</button>
            <div class="mx-auto w-12 h-12 rounded-full bg-[#D4AF37]/10 flex items-center justify-center border border-[#D4AF37]/30 mb-4"><span class="text-xl">🔒</span></div>
            <h3 class="text-xl font-black text-white tracking-wider">解锁后续精彩剧情</h3>
            <p class="text-xs text-slate-300 mt-2">悬念即将揭晓！本集为 <span class="text-gold font-bold">VIP 专属内容</span>，升级会员或消耗积分即可立即观看。</p>
            <div class="my-6 border-t border-[#D4AF37]/20 relative"><span class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-[#0a1e43] px-3 text-[10px] text-slate-400">请选择解锁方式</span></div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left">
                <div onclick="switchPage('vip-page'); closeModal();" class="bg-black/20 border border-[#D4AF37]/40 rounded-xl p-4 flex flex-col justify-between cursor-pointer hover:border-[#D4AF37]">
                    <div><span class="text-[9px] bg-[#D4AF37] text-[#071A3D] font-extrabold px-1.5 py-0.5 rounded-full">🔥 升级 VIP</span><p class="text-[10px] text-slate-400 mt-2">成为会员，海量短剧无限畅看。</p></div>
                    <button class="mt-4 w-full bg-[#D4AF37] text-[#071A3D] text-[11px] font-black py-2 rounded-lg">查看会员方案</button>
                </div>
                <div onclick="switchPage('tasks-page'); closeModal();" class="bg-black/20 border border-white/10 rounded-xl p-4 flex flex-col justify-between cursor-pointer hover:border-[#D4AF37]">
                    <div><span class="text-[9px] bg-slate-800 text-slate-400 font-extrabold px-1.5 py-0.5 rounded-full">🎁 免费看</span><p class="text-[10px] text-slate-400 mt-2">做拉新任务，轻松赚积分兑剧。</p></div>
                    <button class="mt-4 w-full border border-[#D4AF37] text-[#D4AF37] text-[11px] font-bold py-2 rounded-lg">去赚积分</button>
                </div>
            </div>
        </div>
    </div>

    <nav class="sticky top-0 z-40 bg-[#071A3D]/90 border-b border-white/10 backdrop-blur-md px-4 md:px-8 py-4 flex justify-between items-center">
        <div class="flex items-center space-x-8">
            <h1 onclick="switchPage('home-page')" class="text-xl md:text-2xl font-black text-gold tracking-widest cursor-pointer select-none">ROYAL BLUE CLUB</h1>
            <div class="hidden lg:flex space-x-6 text-xs font-semibold uppercase tracking-wider cursor-pointer">
                <span id="nav-home" onclick="switchPage('home-page')" class="text-gold border-b-2 border-gold-bright pb-1">首页</span>
                <span id="nav-vip" onclick="switchPage('vip-page')" class="hover:text-gold transition">VIP会员</span>
                <span id="nav-tasks" onclick="switchPage('tasks-page')" class="hover:text-gold transition">福利中心</span>
                <span id="nav-com" onclick="switchPage('com-page')" class="hover:text-gold transition">社区广场</span>
            </div>
        </div>
        <div>
            <button onclick="switchPage('user-page')" class="bg-gradient-to-r from-[#b8922f] to-[#D4AF37] text-[#071A3D] px-5 py-2 rounded-full text-xs font-black shadow-lg shadow-yellow-600/10">会员中心</button>
        </div>
    </nav>

    <div id="home-page" class="page-content max-w-[1400px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col space-y-12">
        <div class="relative rounded-2xl p-6 md:p-12 border border-[#D4AF37]/20 overflow-hidden bg-gradient-to-r from-[#091f46] via-[#122e61] to-[#071A3D]">
            <div class="relative z-10 max-w-xl space-y-4">
                <h2 class="text-3xl md:text-5xl font-black text-white leading-tight">海量热门短剧<br><span class="text-gold">⚡ 每日更新</span></h2>
                <p class="text-slate-300 text-xs md:text-sm">新用户注册即送尊享俱乐部免费体验特权，全网爽剧一网打尽。</p>
                <button onclick="goToPlay('地府客服中心', 1)" class="bg-gradient-to-r from-[#b8922f] to-[#D4AF37] text-[#071A3D] font-black px-8 py-3 rounded-xl text-xs uppercase tracking-wider">立即抢先看</button>
            </div>
            <div class="absolute right-0 bottom-0 opacity-5 text-[8rem] md:text-[14rem] font-black select-none text-gold pointer-events-none transform translate-x-12 translate-y-12">ROYAL</div>
        </div>

        <section class="space-y-4">
            <h3 class="text-md font-bold text-white border-b border-white/10 pb-2 uppercase tracking-wider">🔥 今日热门短剧 (点击进入剧集详情页)</h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                <div onclick="goToPlay('地府客服中心', 1)" class="group cursor-pointer glass-card p-2 rounded-xl transition">
                    <div class="aspect-[3/4] bg-[#0c2554] rounded-lg mb-2 flex items-center justify-center text-slate-500 relative">
                        <span class="text-xs">海报：地府客服中心</span>
                        <span class="absolute top-2 left-2 bg-[#071A3D]/90 text-gold text-[9px] px-1.5 py-0.5 rounded font-black border border-gold/30">★ 9.8</span>
                    </div>
                    <h4 class="text-white text-xs font-bold truncate group-hover:text-gold transition">地府客服中心</h4>
                    <div class="flex justify-between items-center mt-1 text-[10px] text-slate-400"><span>80集全</span><span>42.1万播放</span></div>
                </div>
                <div onclick="goToPlay('家门口过招', 1)" class="group cursor-pointer glass-card p-2 rounded-xl transition">
                    <div class="aspect-[3/4] bg-[#0c2554] rounded-lg mb-2 flex items-center justify-center text-slate-500 relative">
                        <span class="text-xs">海报：家门口过招</span>
                        <span class="absolute top-2 left-2 bg-[#071A3D]/90 text-gold text-[9px] px-1.5 py-0.5 rounded font-black border border-gold/30">★ 9.5</span>
                    </div>
                    <h4 class="text-white text-xs font-bold truncate group-hover:text-gold transition">家门口过招</h4>
                    <div class="flex justify-between items-center mt-1 text-[10px] text-slate-400"><span>65集全</span><span>31.5万播放</span></div>
                </div>
            </div>
        </section>
    </div>

    <div id="play-page" class="page-content max-w-[1400px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col space-y-6 hidden">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 space-y-4">
                <div id="video-player-container" class="w-full aspect-video bg-black rounded-2xl border border-white/10 flex flex-col items-center justify-center relative overflow-hidden shadow-2xl">
                    <div id="player-state-free" class="absolute inset-0 bg-[#061430] flex flex-col items-center justify-center text-center p-4">
                        <span class="text-4xl animate-bounce">▶</span>
                        <p class="text-xs text-slate-300 mt-2">正在免费试看：<span id="current-playing-title" class="text-gold font-bold"></span></p>
                    </div>
                    <div id="player-state-locked" class="absolute inset-0 bg-black/90 flex flex-col items-center justify-center text-center p-4 hidden">
                        <span class="text-3xl text-gold">🔒</span>
                        <p class="text-sm font-bold text-white mt-2">该剧集需要解锁后观看</p>
                        <button onclick="openModal()" class="mt-4 bg-gold text-[#071A3D] font-black text-xs px-6 py-2 rounded-xl">立即解锁剧集</button>
                    </div>
                </div>
                <div>
                    <h2 id="detail-movie-title" class="text-xl font-black text-white">剧集名称</h2>
                    <p class="text-xs text-slate-400 mt-1">分类：都市、爽剧、逆袭 | 评分：★ 9.8 | 每日凌晨准时更新 2 集</p>
                </div>
            </div>
            <div class="glass-card p-4 rounded-2xl flex flex-col h-[400px] lg:h-auto">
                <h3 class="text-xs font-bold uppercase tracking-widest text-gold border-b border-white/10 pb-2 mb-3">📋 剧集大纲及选集</h3>
                <div class="grid grid-cols-4 gap-2 overflow-y-auto flex-1 pr-1" id="episode-grid">
                    </div>
            </div>
        </div>
    </div>

    <div id="vip-page" class="page-content max-w-[1400px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col space-y-8 hidden">
        <div class="text-center space-y-1"><h2 class="text-2xl font-black text-gold uppercase tracking-widest">👑 尊享皇家俱乐部 VIP</h2><p class="text-slate-400 text-xs">加入至尊会员方案，全网大片海量爽剧任意看</p></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto w-full">
            <div class="bg-gradient-to-b from-[#0c2554] to-[#071A3D] border-2 border-gold-bright rounded-2xl p-6 relative shadow-2xl">
                <span class="absolute top-0 right-0 bg-gold text-[#071A3D] text-[9px] font-black px-3 py-1 rounded-bl-xl uppercase tracking-wider">🌟 极力推荐</span>
                <h4 class="text-white font-bold text-md">季度 极速超级 VIP</h4>
                <div class="text-3xl font-black text-gold my-3">RM 69 <span class="text-xs font-normal text-slate-500">/ 90天</span></div>
                <p class="text-xs text-slate-300 leading-relaxed">平均每天仅需 RM0.76！专享极速 CDN 视频独占服务器通道，超高清画质无任何卡顿延迟。</p>
                <button class="w-full mt-6 bg-gold text-[#071A3D] font-black py-3 rounded-xl text-xs uppercase tracking-widest shadow-lg shadow-yellow-600/20">立即安全支付</button>
            </div>
            <div class="glass-card rounded-2xl p-6 flex flex-col justify-between">
                <div>
                    <h4 class="text-white font-bold text-md">月度 尊享 VIP</h4>
                    <div class="text-3xl font-black text-gold my-3">RM 29 <span class="text-xs font-normal text-slate-500">/ 30天</span></div>
                    <p class="text-xs text-slate-300 leading-relaxed">尝鲜体验卡。全站短剧无限次解锁，免广告纯净流畅体验。</p>
                </div>
                <button class="w-full mt-6 border border-gold text-gold font-bold py-3 rounded-xl text-xs uppercase tracking-widest hover:bg-gold hover:text-[#071A3D] transition">立即开通</button>
            </div>
        </div>
    </div>

    <div id="tasks-page" class="page-content max-w-[1400px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col space-y-8 hidden">
        <div class="text-center space-y-2">
            <h2 class="text-2xl font-black text-white">🎁 零元看剧 · 任务福利中心</h2>
            <p class="text-slate-400 text-xs">不想充值？完成以下白嫖任务，海量积分轻松兑换 VIP 付费集数</p>
            <div class="inline-block bg-black/40 border border-gold/20 px-6 py-1.5 rounded-full text-xs font-bold">当前总剩余积分：<span id="user-points" class="text-gold">45</span> Pt</div>
        </div>
        <div class="max-w-xl mx-auto w-full space-y-3">
            <div class="glass-card p-4 rounded-xl flex justify-between items-center">
                <div><h4 class="text-white text-xs font-bold">🌞 每日登录签到</h4><p class="text-slate-400 text-[11px]">每日手指点一下，立送 5 积分</p></div>
                <button onclick="addPoints(5, '签到成功！积分+5')" class="bg-gold text-[#071A3D] font-black text-[11px] px-4 py-2 rounded-lg">每日签到</button>
            </div>
            <div class="glass-card p-4 rounded-xl flex justify-between items-center">
                <div><h4 class="text-white text-xs font-bold">🔗 复制裂变邀请链接</h4><p class="text-slate-400 text-[11px]">每成功邀请 1 位老乡，送 50 积分 + 1天免费会员</p></div>
                <button onclick="alert('邀请链接已成功复制到剪贴板！快发去Telegram或WhatsApp吧！')" class="border border-gold text-gold font-bold text-[11px] px-4 py-2 rounded-lg">复制链接</button>
            </div>
        </div>
    </div>

    <div id="com-page" class="page-content max-w-[1400px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col space-y-6 hidden">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
            <div class="lg:col-span-1 glass-card p-5 rounded-2xl space-y-4 h-fit">
                <h3 class="text-xs font-bold text-gold uppercase tracking-widest border-l-2 border-gold pl-2">✍ 参与社区互动</h3>
                <textarea id="post-input" rows="4" class="w-full bg-black/40 border border-white/10 rounded-xl p-3 text-xs focus:border-gold outline-none resize-none" placeholder="说说你对刚才看的那一集的想法..."></textarea>
                <button onclick="submitPost()" class="w-full bg-gradient-to-r from-[#b8922f] to-[#D4AF37] text-[#071A3D] font-black py-2.5 rounded-xl text-xs uppercase tracking-wider">发布动态</button>
            </div>
            <div class="lg:col-span-3 space-y-4">
                <h3 class="text-sm font-bold text-white border-b border-white/5 pb-2">💬 皇家俱乐部全员热议墙</h3>
                <div id="post-wall" class="space-y-3">
                    <div class="glass-card p-4 rounded-xl space-y-2">
                        <div class="flex justify-between items-center text-xs"><span class="text-gold font-bold">大马短剧一哥 👑</span><span class="text-slate-500 text-[10px]">3分钟前</span></div>
                        <p class="text-white text-xs leading-relaxed">刚刚在 Royal Blue 看完《地府客服中心》前5集，笑料太足了！第6集居然是个超级大反转卡点，爱了爱了！</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="user-page" class="page-content max-w-[1400px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col items-center justify-center hidden">
        <div class="max-w-md w-full glass-card rounded-2xl p-6 text-center space-y-6">
            <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-gold to-yellow-600 mx-auto flex items-center justify-center border-4 border-[#071A3D] shadow-xl"><span class="text-3xl">🤵</span></div>
            <div>
                <h3 class="text-lg font-black text-white tracking-wide">尊贵皇家会员_0894</h3>
                <p class="text-[10px] text-gold uppercase tracking-widest font-bold mt-1">💎 VIP 会员等级: V2 钻石级俱乐部</p>
            </div>
            <div class="grid grid-cols-2 gap-2 border-t border-b border-white/5 py-4 text-left text-xs">
                <div>账户状态: <span class="text-green-400 font-bold">正常</span></div>
                <div>积分余额: <span class="text-gold font-bold id-point-placeholder">45</span> Pt</div>
            </div>
            <div class="space-y-2">
                <p class="text-[11px] text-slate-400">更流畅的防断流纯净追剧体验，建议立刻安装独立客户端：</p>
                <button onclick="alert('独立高防 Android APK 正在启动加密通道下载...')" class="w-full bg-gradient-to-r from-[#b8922f] to-[#D4AF37] text-[#071A3D] font-black py-3 rounded-xl text-xs uppercase tracking-widest shadow-md">📲 Android APK 官方安全下载</button>
            </div>
        </div>
    </div>

    <footer class="bg-[#041129] border-t border-white/5 mt-12 py-6 text-center text-xs text-slate-500"><p>Copyright © 2026 Royal Blue Club. All Rights Reserved.</p></footer>

    <script>
        let currentPoints = 45;

        // 1. 核心导航多页控制
        function switchPage(pageId) {
            document.querySelectorAll('.page-content').forEach(p => p.classList.add('hidden'));
            document.getElementById(pageId).classList.remove('hidden');

            // 导航高亮清空
            const navs = ['nav-home', 'nav-vip', 'nav-tasks', 'nav-com'];
            navs.forEach(n => { if(document.getElementById(n)) document.getElementById(n).className = "hover:text-gold transition"; });

            if(pageId === 'home-page' && document.getElementById('nav-home')) document.getElementById('nav-home').className = "text-gold border-b-2 border-gold-bright pb-1";
            if(pageId === 'vip-page' && document.getElementById('nav-vip')) document.getElementById('nav-vip').className = "text-gold border-b-2 border-gold-bright pb-1";
            if(pageId === 'tasks-page' && document.getElementById('nav-tasks')) document.getElementById('nav-tasks').className = "text-gold border-b-2 border-gold-bright pb-1";
            if(pageId === 'com-page' && document.getElementById('nav-com')) document.getElementById('nav-com').className = "text-gold border-b-2 border-gold-bright pb-1";

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // 2. 模拟进入短剧详情页并动态铺排 20 集
        function goToPlay(movieTitle, targetEpisode) {
            switchPage('play-page');
            document.getElementById('detail-movie-title').innerText = movieTitle;
            
            const grid = document.getElementById('episode-grid');
            grid.innerHTML = ''; // 清空

            for (let i = 1; i <= 20; i++) {
                const btn = document.createElement('button');
                btn.className = "ep-btn py-3 rounded-xl text-xs font-bold relative flex items-center justify-center";
                
                if (i <= 5) {
                    btn.innerHTML = `${i} <span class="absolute top-0 right-0 text-[8px] bg-green-600 text-white px-1 rounded-bl-md rounded-tr-xl">免费</span>`;
                    btn.onclick = () => loadVideoState(movieTitle, i, true);
                } else {
                    btn.innerHTML = `${i} <span class="absolute top-0 right-0 text-[8px] bg-amber-600 text-white px-1 rounded-bl-md rounded-tr-xl">🔒</span>`;
                    btn.onclick = () => loadVideoState(movieTitle, i, false);
                }
                grid.appendChild(btn);
            }
            // 默认加载第一集
            loadVideoState(movieTitle, targetEpisode, targetEpisode <= 5);
        }

        // 3. 剧集鉴权拦截网关状态切换
        function loadVideoState(title, num, isFree) {
            document.getElementById('current-playing-title').innerText = `${title} - 第 ${num} 集`;
            if (isFree) {
                document.getElementById('player-state-free').classList.remove('hidden');
                document.getElementById('player-state-locked').classList.add('hidden');
            } else {
                document.getElementById('player-state-free').classList.add('hidden');
                document.getElementById('player-state-locked').classList.remove('hidden');
                openModal(); // 自动拉起双重变现拦截弹窗
            }
        }

        // 4. 社区动态发帖功能
        function submitPost() {
            const input = document.getElementById('post-input');
            if(!input.value.trim()) return alert('请输入一些想法再发布哦！');
            
            const wall = document.getElementById('post-wall');
            const newPost = document.createElement('div');
            newPost.className = "glass-card p-4 rounded-xl space-y-2 animate-fadeIn";
            newPost.innerHTML = `
                <div class="flex justify-between items-center text-xs"><span class="text-gold font-bold">尊贵皇家会员_0894 💎</span><span class="text-slate-500 text-[10px]">刚刚</span></div>
                <p class="text-white text-xs leading-relaxed">${input.value}</p>
            `;
            wall.insertBefore(newPost, wall.firstChild);
            input.value = '';
        }

        // 5. 辅助增分器（演示用）
        function addPoints(amt, msg) {
            currentPoints += amt;
            document.getElementById('user-points').innerText = currentPoints;
            document.querySelectorAll('.id-point-placeholder').forEach(el => el.innerText = currentPoints);
            alert(msg);
        }

        function openModal() { document.getElementById('conversion-modal').classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
        function closeModal() { document.getElementById('conversion-modal').classList.add('hidden'); document.body.style.overflow = ''; }
    </script>
</body>
</html>
